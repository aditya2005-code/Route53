# ==============================================================================
# AWS Route 53 Clone - Backend Configuration Template
# Copy this file to '.env' and modify variables for production deployment.
# ==============================================================================

# Database connection URL
# Use SQLite locally. For production databases (PostgreSQL/MySQL), configure appropriately.
DATABASE_URL=sqlite:///./route53.db

# JWT Secret Key - MUST change this in production to a strong, random 32+ char hex key
# Generate key via terminal: openssl rand -hex 32
SECRET_KEY=route53clone_secret_key_change_me_in_production

# JWT algorithm for encoding/decoding tokens
ALGORITHM=HS256

# JWT token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Allowed CORS Origins - Comma-separated domains allowing API access
# e.g., http://localhost:3000,https://route53-clone.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
